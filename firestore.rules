rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User vaults are private to the authenticated owner UID
    match /user_vaults/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    
    // Community Rooms are public to read, but only writable by the owner UID matching the document prefix
    match /community_rooms/{roomId} {
      allow read: if true;
      allow write: if request.auth != null && roomId.startsWith(request.auth.uid + "_");
    }
    
    // Shared Snapshots are public to read, but only writable by the owner UID
    match /shared_rooms/{shareId} {
      allow read: if true;
      allow create: if request.auth != null 
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null 
        && resource.data.ownerUid == request.auth.uid
        && (request.method == 'delete' || request.resource.data.ownerUid == request.auth.uid);
    }
  }
}
